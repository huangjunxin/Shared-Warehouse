# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_NAME=warehouse
DB_USER=postgres
DB_PASSWORD=your_password

# JWT配置
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRES_IN=7d

# 服务器配置
PORT=3000
NODE_ENV=development
# 跨域前端地址，多个地址使用英文逗号分隔。开发环境保留下面的 localhost 默认值；
# 前端单独部署时，生产环境必须替换为准确的 Origin，例如 https://warehouse.example.com
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
